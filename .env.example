# Discord bot token (required)
DISCORD_BOT_TOKEN=your_bot_token_here

# Comma-separated channel IDs to log
DISCORD_CHANNEL_IDS=123456789012345678,987654321098765432

# Where to store log files (default: ./logs)
LOG_DIR=./logs

# Where to store state (last message ID per channel) (default: ./state)
STATE_DIR=./state

# Poll interval in seconds (only used by watch mode, cron ignores this)
POLL_INTERVAL=300
